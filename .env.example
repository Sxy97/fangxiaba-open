PORT=3000
NODE_ENV=development

# Optional. Comma-separated origins if API and H5 are served from different domains.
ALLOWED_ORIGINS=

# Optional. Set to 0 if you deploy without a reverse proxy.
TRUST_PROXY=1

# Optional. Skip browser warmup for faster local boot.
PLAYWRIGHT_WARMUP=1

# Optional Playwright proxy.
PLAYWRIGHT_PROXY_SERVER=
PLAYWRIGHT_PROXY_USERNAME=
PLAYWRIGHT_PROXY_PASSWORD=

# Request limits and cache tuning.
MAX_LOOKUP_COUNT=15
MAX_COMMENT_COUNT=20
PLAYWRIGHT_CONCURRENCY=2
PLAYWRIGHT_QUEUE_MAX=20
PLAYWRIGHT_QUEUE_TIMEOUT_MS=20000
LOOKUP_JOB_TTL_MS=600000
